MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=ai_dashboard
JWT_SECRET=change-this-secret
CORS_ORIGIN=http://127.0.0.1:5173
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://192.168.1.10:5173

# Dashboard -> local AI inference (backend/app.py, default port 5000)
AI_BACKEND_URL=http://127.0.0.1:5000
# Allow long first-time model download + BLIP-2 inference (seconds)
AI_BACKEND_READ_TIMEOUT_SECONDS=300

OPENAI_API_KEY=your_openai_api_key
OPENAI_VLM_MODEL=gpt-4.1-mini

# --- AI inference process (backend/app.py) — copy these into backend/.env or set in the shell ---
# PORT=5000
# YOLO_MODEL_PATH=yolov8n.pt
# Base HF model id OR leave unset and use fine-tuned folder via VLM_FINETUNED_PATH
# VLM_MODEL=Salesforce/blip2-opt-2.7b
# VLM_FINETUNED_PATH=artifacts/vlm-finetuned
# ENABLE_HEAVY_VLM=1
# PRELOAD_AI_PIPELINE=1
# ANALYSIS_TIMEOUT_SECONDS=120
# FAST_AI_MODE=0
